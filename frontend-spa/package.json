{
  "name": "customer-feedback-spa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
